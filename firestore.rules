rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read/write their own profile.
    // Admins (isAdmin == true in their own doc) can read/write any profile.
    match /users/{uid} {
      allow read: if request.auth != null
                  && (request.auth.uid == uid
                      || request.auth.uid == 'kMZlGUDl3lPFm2VIyc5eyYHhA752'
                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow write: if request.auth != null
                   && (request.auth.uid == uid
                       || request.auth.uid == 'kMZlGUDl3lPFm2VIyc5eyYHhA752'
                       || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }

    // Configurators: owner can read/write; anyone can read published ones
    match /configurators/{id} {
      allow read: if resource.data.published == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Orders: anyone can create (submitted from public embed, no auth).
    // Only the configurator owner can read their orders.
    match /orders/{orderId} {
      allow create: if request.resource.data.keys().hasAll(['configuratorId', 'ownerId']);
      allow read, update, delete: if request.auth != null
                                  && request.auth.uid == resource.data.ownerId;
    }

    // Analytics: anyone can write (tracked from public embed).
    // Any authenticated user can read (owners check their own stats).
    match /analytics/{configId} {
      allow write: if true;
      allow read:  if request.auth != null;
    }

    // Landing pages: owner can read/write; anyone can read published ones
    match /landingPages/{id} {
      allow read: if resource.data.published == true
                  || (request.auth != null && request.auth.uid == resource.data.ownerId);
      allow write: if request.auth != null && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
    }

    // Media metadata (Firestore side)
    match /media/{mediaId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
    }

    // Invoices: server writes for real payments; users can create + read their own
    match /invoices/{invoiceId} {
      allow read:   if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // Revisions: owner can read/write their own
    match /revisions/{revId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == resource.data.ownerId;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }

    // Invoice counter (server-only)
    match /meta/{docId} {
      allow read, write: if false;
    }

    // Model inquiries: anyone can submit; only admins can read
    match /model_inquiries/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'description']);
      allow read, update, delete: if request.auth != null
                                  && (request.auth.uid == 'kMZlGUDl3lPFm2VIyc5eyYHhA752'
                                      || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
  }
}
