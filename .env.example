# Firebase — copy from your Firebase project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# PayPal — from developer.paypal.com
VITE_PAYPAL_CLIENT_ID=

# PayPal billing plan IDs — create one plan per tier in PayPal developer dashboard
# Each plan: 7-day free trial, then monthly billing
VITE_PAYPAL_PLAN_ID_STARTER=       # €60/month, 3 embeds
VITE_PAYPAL_PLAN_ID_PRO=           # €120/month, 9 embeds
VITE_PAYPAL_PLAN_ID_BUSINESS=      # €180/month, 18 embeds
VITE_PAYPAL_PLAN_ID_ENTERPRISE=    # €680/month, 50 embeds

# Stripe — from dashboard.stripe.com
VITE_STRIPE_PRICE_ID_STARTER=      # €60/month price ID (e.g. price_xxx)
VITE_STRIPE_PRICE_ID_PRO=          # €120/month price ID
VITE_STRIPE_PRICE_ID_BUSINESS=     # €180/month price ID
VITE_STRIPE_PRICE_ID_ENTERPRISE=   # €680/month price ID

# Server-side only (Firebase Functions)
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
